### Variables
@baseUrl = http://localhost:8080
@shortcode = abc1234
@jwt = Bearer YOUR_JWT_TOKEN_HERE

### 0) Register user
POST {{baseUrl}}/api/auth/register
Content-Type: application/json

{
  "email": "admin@example.com",
  "contrasena": "Password123!"
}

### 1) Login to get JWT
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "admin@example.com",
  "contrasena": "Password123!"
}

### 2) Create link
POST {{baseUrl}}/api/core/links/create
Content-Type: application/json

{
  "codigoCorto": "",
  "urlOriginal": "https://example.com",
  "esDinamico": false,
  "tipoHerramienta": "QR"
}

### 3) Redirect by shortcode
GET {{baseUrl}}/api/core/links/public/{{shortcode}}

### 4) Public link info
GET {{baseUrl}}/api/v1/public/enlaces/{{shortcode}}

### 5) Management list (JWT protected)
GET {{baseUrl}}/api/management/links/list
Authorization: {{jwt}}
Accept: application/json

### 6) Tools
GET {{baseUrl}}/api/v1/tools/qr?url=https://google.com
GET {{baseUrl}}/api/v1/tools/opengraph?url=https://github.com
